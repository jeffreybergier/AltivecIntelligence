include sqlite_common.mk

SQLITE_ZIP  = sqlite-amalgamation-$(SQLITE_VER).zip
SQLITE_URL  = https://www.sqlite.org/$(SQLITE_YEAR)/$(SQLITE_ZIP)
SQLITE_URLS = $(SQLITE_URL) https://sqlite.org/$(SQLITE_YEAR)/$(SQLITE_ZIP)
SQLITE_DIR  = sqlite-amalgamation-$(SQLITE_VER)
TARBALL_DIR = tarballs

CWD          = $(shell pwd)
BUILD_ROOT   = $(CWD)/build-mac
INTERMEDIATE = $(BUILD_ROOT)/intermediate
PREFIX       = $(BUILD_ROOT)/prefix

PPC_FLAGS   = -arch ppc -mmacosx-version-min=$(MAC_MIN_PPC) -isysroot $(SDK_PPC_PATH) $(LEGACY_GCC_FLAGS)
X86_FLAGS   = -arch i386 -mmacosx-version-min=$(MAC_MIN_X86) -isysroot $(SDK_X86_PATH) $(LEGACY_GCC_FLAGS)
X64_FLAGS   = -target x86_64-apple-macos$(MAC_MIN_X64) -isysroot $(SDK_X64_PATH) -B$(BIN_DIR)
ARM64_FLAGS = -target arm64-apple-macos$(MAC_MIN_ARM64) -isysroot $(SDK_ARM64_PATH) -B$(BIN_DIR)

SRC = $(INTERMEDIATE)/$(SQLITE_DIR)/sqlite3.c

all: static

static: $(BUILD_ROOT)/lib/libsqlite3.a
	@echo "-----------------------------------------------------------"
	@echo "MAC QUAD-FAT (ppc, x86, x64, arm64) BUILD SUCCESSFUL"
	@echo "Libraries: $(BUILD_ROOT)/lib"
	@echo "Headers:   $(BUILD_ROOT)/include"
	@echo "-----------------------------------------------------------"

$(BUILD_ROOT)/lib/libsqlite3.a: $(PREFIX)/lib/libsqlite3.a
	mkdir -p $(BUILD_ROOT)/lib $(BUILD_ROOT)/include
	cp $(PREFIX)/lib/libsqlite3.a $(BUILD_ROOT)/lib/
	cp $(INTERMEDIATE)/$(SQLITE_DIR)/sqlite3.h $(BUILD_ROOT)/include/

$(TARBALL_DIR):
	mkdir -p $@

$(TARBALL_DIR)/$(SQLITE_ZIP): | $(TARBALL_DIR)
	$(call download_to_target,$(SQLITE_URLS))

$(INTERMEDIATE)/$(SQLITE_DIR): $(TARBALL_DIR)/$(SQLITE_ZIP)
	mkdir -p $(INTERMEDIATE)
	cd $(INTERMEDIATE) && unzip -q $(CWD)/$(TARBALL_DIR)/$(SQLITE_ZIP)

$(PREFIX)/lib/libsqlite3.a: $(INTERMEDIATE)/$(SQLITE_DIR)
	mkdir -p $(PREFIX)/ppc/lib $(PREFIX)/x86/lib $(PREFIX)/x64/lib $(PREFIX)/arm64/lib $(PREFIX)/lib
	@echo "--- Building SQLite $(SQLITE_VER) (ppc) ---"
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_PPC) $(COMPILER_PPC) $(PPC_FLAGS) $(OPT_FLAGS) \
	  $(LEGACY_SQLITE_CFLAGS) -c $(SRC) -o $(INTERMEDIATE)/sqlite3-ppc.o
	$(AR_LEGACY) rc $(PREFIX)/ppc/lib/libsqlite3.a $(INTERMEDIATE)/sqlite3-ppc.o
	$(RANLIB_LEGACY) $(PREFIX)/ppc/lib/libsqlite3.a
	@echo "--- Building SQLite $(SQLITE_VER) (x86) ---"
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_X86) $(COMPILER_X86) $(X86_FLAGS) $(OPT_FLAGS) \
	  $(LEGACY_SQLITE_CFLAGS) -c $(SRC) -o $(INTERMEDIATE)/sqlite3-x86.o
	$(AR_LEGACY) rc $(PREFIX)/x86/lib/libsqlite3.a $(INTERMEDIATE)/sqlite3-x86.o
	$(RANLIB_LEGACY) $(PREFIX)/x86/lib/libsqlite3.a
	@echo "--- Building SQLite $(SQLITE_VER) (x64) ---"
	$(COMPILER_X64) $(X64_FLAGS) $(OPT_FLAGS) \
	  $(SQLITE_CFLAGS) -c $(SRC) -o $(INTERMEDIATE)/sqlite3-x64.o
	$(AR_MODERN) rc $(PREFIX)/x64/lib/libsqlite3.a $(INTERMEDIATE)/sqlite3-x64.o
	$(RANLIB_MODERN) $(PREFIX)/x64/lib/libsqlite3.a
	@echo "--- Building SQLite $(SQLITE_VER) (arm64) ---"
	$(COMPILER_ARM64) $(ARM64_FLAGS) $(OPT_FLAGS) \
	  $(SQLITE_CFLAGS) -c $(SRC) -o $(INTERMEDIATE)/sqlite3-arm64.o
	$(AR_MODERN) rc $(PREFIX)/arm64/lib/libsqlite3.a $(INTERMEDIATE)/sqlite3-arm64.o
	$(RANLIB_MODERN) $(PREFIX)/arm64/lib/libsqlite3.a
	@echo "--- Merging quad-fat libsqlite3.a ---"
	$(LIPO) -create \
	  $(PREFIX)/ppc/lib/libsqlite3.a \
	  $(PREFIX)/x86/lib/libsqlite3.a \
	  $(PREFIX)/x64/lib/libsqlite3.a \
	  $(PREFIX)/arm64/lib/libsqlite3.a \
	  -output $(PREFIX)/lib/libsqlite3.a

clean:
	rm -rf $(BUILD_ROOT)

.PHONY: all static clean
