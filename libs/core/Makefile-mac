	@echo "--- Building cJSON (arm64) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/arm64/lib $(STAMP_DIR)
	$(COMPILER_ARM64) $(ARM64_COMPILE_FLAGS) $(CJSON_CFLAGS) \
	  -c $(CJSON_DIR)/cJSON.c \
	  -o $(INTERMEDIATE)/cJSON-arm64.o
	$(COMPILER_ARM64) $(ARM64_COMPILE_FLAGS) $(CJSON_CFLAGS) \
	  -c $(CJSON_DIR)/cJSON_Utils.c \
	  -o $(INTERMEDIATE)/cJSON_Utils-arm64.o
	$(AR_MODERN) rc $(PREFIX)/arm64/lib/libcjson.a \
	  $(INTERMEDIATE)/cJSON-arm64.o $(INTERMEDIATE)/cJSON_Utils-arm64.o
