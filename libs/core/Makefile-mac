include core_common.mk

CWD=$(shell pwd)
BUILD_ROOT=$(CWD)/build-mac
INTERMEDIATE=$(BUILD_ROOT)/intermediate
PREFIX=$(BUILD_ROOT)/prefix
STAMP_DIR=$(BUILD_ROOT)/stamps
PUBLIC_LIB_DIR=$(BUILD_ROOT)/lib
PUBLIC_INCLUDE_DIR=$(BUILD_ROOT)/include

CURL_DIR ?= $(CWD)/../libcurl/build-mac
SQLITE_DIR ?= $(CWD)/../sqlite/build-mac
CJSON_DIR=third_party/cJSON

PPC_FLAGS=-arch ppc -mmacosx-version-min=$(MAC_MIN_PPC) -isysroot $(SDK_PPC_PATH) $(LEGACY_GCC_FLAGS)
X86_FLAGS=-arch i386 -mmacosx-version-min=$(MAC_MIN_X86) -isysroot $(SDK_X86_PATH) $(LEGACY_GCC_FLAGS)
X64_FLAGS=-target x86_64-apple-macos$(MAC_MIN_X64) -isysroot $(SDK_X64_PATH) -Wl,-platform_version,macos,$(MAC_MIN_X64),11.3 -fuse-ld=$(LD64_LLD) -B$(BIN_DIR)
ARM64_FLAGS=-target arm64-apple-macos$(MAC_MIN_ARM64) -isysroot $(SDK_ARM64_PATH) -Wl,-platform_version,macos,$(MAC_MIN_ARM64),11.3 -fuse-ld=$(LD64_LLD) -B$(BIN_DIR)
X64_COMPILE_FLAGS=-target x86_64-apple-macos$(MAC_MIN_X64) -isysroot $(SDK_X64_PATH) -B$(BIN_DIR)
ARM64_COMPILE_FLAGS=-target arm64-apple-macos$(MAC_MIN_ARM64) -isysroot $(SDK_ARM64_PATH) -B$(BIN_DIR)

CJSON_CFLAGS=$(OPT_FLAGS) $(COMMON_WARN_FLAGS) -std=c99 -I$(CJSON_DIR)

CORE_COMPONENT_LIBS=libAICURLConnection.a \
                    libcurl.a \
                    libssl.a \
                    libcrypto.a \
                    libz.a \
                    libsqlite3.a \
                    libcjson.a
CORE_STATIC_LIBS=libAltivecCore.a $(CORE_COMPONENT_LIBS)
PUBLIC_LIBS=$(addprefix $(PUBLIC_LIB_DIR)/,$(CORE_STATIC_LIBS))
PUBLIC_COMPONENT_LIBS=$(addprefix $(PUBLIC_LIB_DIR)/,$(CORE_COMPONENT_LIBS))
CURL_PUBLIC_FILES=libAICURLConnection.a \
                  libcurl.a \
                  libssl.a \
                  libcrypto.a \
                  libz.a \
                  cacert.pem
SQLITE_PUBLIC_FILES=libsqlite3.a
CORE_INPUTS_PPC=$(INTERMEDIATE)/thin/ppc/libAltivecCoreWrapper.a \
                $(addprefix $(INTERMEDIATE)/thin/ppc/,$(CORE_COMPONENT_LIBS))
CORE_INPUTS_X86=$(INTERMEDIATE)/thin/x86/libAltivecCoreWrapper.a \
                $(addprefix $(INTERMEDIATE)/thin/x86/,$(CORE_COMPONENT_LIBS))
CORE_INPUTS_X64=$(INTERMEDIATE)/thin/x64/libAltivecCoreWrapper.a \
                $(addprefix $(INTERMEDIATE)/thin/x64/,$(CORE_COMPONENT_LIBS))
CORE_INPUTS_ARM64=$(INTERMEDIATE)/thin/arm64/libAltivecCoreWrapper.a \
                  $(addprefix $(INTERMEDIATE)/thin/arm64/,$(CORE_COMPONENT_LIBS))

FRAMEWORK_NAME=AltivecCore
FRAMEWORK_INFO_PLIST=Resources/Info-mac.plist
FRAMEWORK_VERSION=A
FRAMEWORK_BUNDLE=$(PUBLIC_LIB_DIR)/$(FRAMEWORK_NAME).framework
FRAMEWORK_VERSION_DIR=$(FRAMEWORK_BUNDLE)/Versions/$(FRAMEWORK_VERSION)
FRAMEWORK_INSTALL_NAME=@executable_path/../Frameworks/$(FRAMEWORK_NAME).framework/Versions/$(FRAMEWORK_VERSION)/$(FRAMEWORK_NAME)
FRAMEWORK_CURRENT_VER=$(call plist_version,$(FRAMEWORK_INFO_PLIST))
FRAMEWORK_COMPAT_VER=$(FRAMEWORK_CURRENT_VER)
DYLIB_LINK_FLAGS=-dynamiclib \
                 -install_name $(FRAMEWORK_INSTALL_NAME) \
                 -compatibility_version $(FRAMEWORK_COMPAT_VER) \
                 -current_version $(FRAMEWORK_CURRENT_VER) \
                 -Wl,-headerpad_max_install_names

all: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem \
     $(PUBLIC_INCLUDE_DIR)/.stamp verify-mac \
     $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) verify-dynamic
	@echo "-----------------------------------------------------------"
	@echo "MAC QUAD-FAT STATIC + ALTIVECCORE FRAMEWORK BUILD SUCCESSFUL"
	@echo "Libraries: $(PUBLIC_LIB_DIR)"
	@echo "Framework: $(FRAMEWORK_BUNDLE)"
	@echo "Headers:   $(PUBLIC_INCLUDE_DIR)"
	@echo "-----------------------------------------------------------"
	@$(MAKE) --no-print-directory -f Makefile-mac prune-build-files

static: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem \
        $(PUBLIC_INCLUDE_DIR)/.stamp verify-mac
	@echo "-----------------------------------------------------------"
	@echo "MAC ALTIVECCORE STATIC LIBS BUILD SUCCESSFUL"
	@echo "Libraries: $(PUBLIC_LIB_DIR)"
	@echo "Headers:   $(PUBLIC_INCLUDE_DIR)"
	@echo "-----------------------------------------------------------"
	@$(MAKE) --no-print-directory -f Makefile-mac prune-build-files

dynamic: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem \
         $(PUBLIC_INCLUDE_DIR)/.stamp \
         $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) verify-dynamic
	@echo "-----------------------------------------------------------"
	@echo "MAC ALTIVECCORE FRAMEWORK BUILD SUCCESSFUL"
	@echo "Framework: $(FRAMEWORK_BUNDLE)"
	@echo "-----------------------------------------------------------"
	@$(MAKE) --no-print-directory -f Makefile-mac prune-build-files

curl-ready:
	@if [ ! -f "$(CURL_DIR)/lib/libAICURLConnection.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libcurl.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libssl.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libcrypto.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libz.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/cacert.pem" ] || \
	    [ ! -f "$(CURL_DIR)/include/AICURLConnection.h" ]; then \
		echo "--- Building Mac libcurl static dependency ---"; \
		$(MAKE) -C $(CWD)/../libcurl mac-static; \
	fi

sqlite-ready:
	@if [ ! -f "$(SQLITE_DIR)/lib/libsqlite3.a" ] || \
	    [ ! -f "$(SQLITE_DIR)/include/sqlite3.h" ]; then \
		echo "--- Building Mac SQLite static dependency ---"; \
		$(MAKE) -C $(CWD)/../sqlite mac; \
	fi

$(addprefix $(PUBLIC_LIB_DIR)/,$(CURL_PUBLIC_FILES)): $(PUBLIC_LIB_DIR)/%: | curl-ready
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $(CURL_DIR)/lib/$* $@

$(addprefix $(PUBLIC_LIB_DIR)/,$(SQLITE_PUBLIC_FILES)): $(PUBLIC_LIB_DIR)/%: | sqlite-ready
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $(SQLITE_DIR)/lib/$* $@

define thin_component_rule
$(INTERMEDIATE)/thin/$1/%.a: $(PUBLIC_LIB_DIR)/%.a
	mkdir -p $$(dir $$@)
	$2 $$< -thin $3 -output $$@
endef

$(eval $(call thin_component_rule,ppc,$(LIPO),ppc))
$(eval $(call thin_component_rule,x86,$(LIPO),i386))
$(eval $(call thin_component_rule,x64,$(LIPO),x86_64))
$(eval $(call thin_component_rule,arm64,$(LIPO),arm64))

$(INTERMEDIATE)/thin/ppc/libAltivecCoreWrapper.a: AltivecCore.m \
                                                  AltivecCore.h \
                                                  $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Building AltivecCore wrapper (ppc) ---"
	mkdir -p $(INTERMEDIATE) $(INTERMEDIATE)/thin/ppc
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_PPC) $(COMPILER_PPC) $(PPC_FLAGS) \
	  $(OPT_FLAGS) $(COMMON_WARN_FLAGS) -I$(PUBLIC_INCLUDE_DIR) \
	  -c AltivecCore.m -o $(INTERMEDIATE)/AltivecCore-ppc.o
	$(AR_LEGACY) rc $@ \
	  $(INTERMEDIATE)/AltivecCore-ppc.o
	$(RANLIB_LEGACY) $@

$(INTERMEDIATE)/thin/x86/libAltivecCoreWrapper.a: AltivecCore.m \
                                                  AltivecCore.h \
                                                  $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Building AltivecCore wrapper (i386) ---"
	mkdir -p $(INTERMEDIATE) $(INTERMEDIATE)/thin/x86
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_X86) $(COMPILER_X86) $(X86_FLAGS) \
	  $(OPT_FLAGS) $(COMMON_WARN_FLAGS) -I$(PUBLIC_INCLUDE_DIR) \
	  -c AltivecCore.m -o $(INTERMEDIATE)/AltivecCore-x86.o
	$(AR_LEGACY) rc $@ \
	  $(INTERMEDIATE)/AltivecCore-x86.o
	$(RANLIB_LEGACY) $@

$(INTERMEDIATE)/thin/x64/libAltivecCoreWrapper.a: AltivecCore.m \
                                                  AltivecCore.h \
                                                  $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Building AltivecCore wrapper (x86_64) ---"
	mkdir -p $(INTERMEDIATE) $(INTERMEDIATE)/thin/x64
	$(COMPILER_X64) $(X64_COMPILE_FLAGS) $(OPT_FLAGS) \
	  $(COMMON_WARN_FLAGS) -I$(PUBLIC_INCLUDE_DIR) \
	  -c AltivecCore.m -o $(INTERMEDIATE)/AltivecCore-x64.o
	$(AR_MODERN) rc $@ \
	  $(INTERMEDIATE)/AltivecCore-x64.o
	$(RANLIB_MODERN) $@

$(INTERMEDIATE)/thin/arm64/libAltivecCoreWrapper.a: AltivecCore.m \
                                                    AltivecCore.h \
                                                    $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Building AltivecCore wrapper (arm64) ---"
	mkdir -p $(INTERMEDIATE) $(INTERMEDIATE)/thin/arm64
	$(COMPILER_ARM64) $(ARM64_COMPILE_FLAGS) $(OPT_FLAGS) \
	  $(COMMON_WARN_FLAGS) -I$(PUBLIC_INCLUDE_DIR) \
	  -c AltivecCore.m -o $(INTERMEDIATE)/AltivecCore-arm64.o
	$(AR_MODERN) rc $@ \
	  $(INTERMEDIATE)/AltivecCore-arm64.o
	$(RANLIB_MODERN) $@

$(PREFIX)/ppc/lib/libAltivecCore.a: $(CORE_INPUTS_PPC)
	@echo "--- Aggregating AltivecCore static archive (ppc) ---"
	mkdir -p $(PREFIX)/ppc/lib
	$(LIBTOOL_LEGACY) -static -no_warning_for_no_symbols -o $@ $^

$(PREFIX)/x86/lib/libAltivecCore.a: $(CORE_INPUTS_X86)
	@echo "--- Aggregating AltivecCore static archive (i386) ---"
	mkdir -p $(PREFIX)/x86/lib
	$(LIBTOOL_LEGACY) -static -no_warning_for_no_symbols -o $@ $^

$(PREFIX)/x64/lib/libAltivecCore.a: $(CORE_INPUTS_X64)
	@echo "--- Aggregating AltivecCore static archive (x86_64) ---"
	mkdir -p $(PREFIX)/x64/lib
	$(LIBTOOL_MODERN) -static --no_warning_for_no_symbols -o $@ $^

$(PREFIX)/arm64/lib/libAltivecCore.a: $(CORE_INPUTS_ARM64)
	@echo "--- Aggregating AltivecCore static archive (arm64) ---"
	mkdir -p $(PREFIX)/arm64/lib
	$(LIBTOOL_MODERN) -static --no_warning_for_no_symbols -o $@ $^

$(PREFIX)/lib/libAltivecCore.a: $(PREFIX)/ppc/lib/libAltivecCore.a \
                                $(PREFIX)/x86/lib/libAltivecCore.a \
                                $(PREFIX)/x64/lib/libAltivecCore.a \
                                $(PREFIX)/arm64/lib/libAltivecCore.a
	mkdir -p $(PREFIX)/lib
	$(LIPO) -create $(PREFIX)/ppc/lib/libAltivecCore.a \
	                 $(PREFIX)/x86/lib/libAltivecCore.a \
	                 $(PREFIX)/x64/lib/libAltivecCore.a \
	                 $(PREFIX)/arm64/lib/libAltivecCore.a \
	                 -output $@

$(PUBLIC_LIB_DIR)/libAltivecCore.a: $(PREFIX)/lib/libAltivecCore.a
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(STAMP_DIR)/cjson-ppc.done: $(CJSON_DIR)/cJSON.c $(CJSON_DIR)/cJSON_Utils.c \
                              $(CJSON_DIR)/cJSON.h $(CJSON_DIR)/cJSON_Utils.h
