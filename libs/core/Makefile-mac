	$(LIPO) -create $(PREFIX)/ppc/lib/libcjson.a \
	                 $(PREFIX)/x86/lib/libcjson.a \
	                 $(PREFIX)/x64/lib/libcjson.a \
	                 $(PREFIX)/arm64/lib/libcjson.a \
	                 -output $@

$(PUBLIC_LIB_DIR)/libcjson.a: $(PREFIX)/lib/libcjson.a
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(PUBLIC_INCLUDE_DIR)/.stamp: AltivecCore.h | curl-ready sqlite-ready
	mkdir -p $(PUBLIC_INCLUDE_DIR)
	rm -rf $(PUBLIC_INCLUDE_DIR)/curl $(PUBLIC_INCLUDE_DIR)/openssl \
	       $(PUBLIC_INCLUDE_DIR)/AltivecCore
	cp -R $(CURL_DIR)/include/* $(PUBLIC_INCLUDE_DIR)/
	rm -f $(PUBLIC_INCLUDE_DIR)/AltivecCURL.h
	cp $(SQLITE_DIR)/include/sqlite3.h $(PUBLIC_INCLUDE_DIR)/
	cp $(CJSON_DIR)/cJSON.h $(PUBLIC_INCLUDE_DIR)/
	cp $(CJSON_DIR)/cJSON_Utils.h $(PUBLIC_INCLUDE_DIR)/
	cp AltivecCore.h $(PUBLIC_INCLUDE_DIR)/
	mkdir -p $(PUBLIC_INCLUDE_DIR)/AltivecCore
	cp $(PUBLIC_INCLUDE_DIR)/AltivecCore.h \
	   $(PUBLIC_INCLUDE_DIR)/AICURLConnection.h \
	   $(PUBLIC_INCLUDE_DIR)/zlib.h \
	   $(PUBLIC_INCLUDE_DIR)/sqlite3.h \
	   $(PUBLIC_INCLUDE_DIR)/cJSON.h \
	   $(PUBLIC_INCLUDE_DIR)/cJSON_Utils.h \
	   $(PUBLIC_INCLUDE_DIR)/AltivecCore/
	cp -R $(PUBLIC_INCLUDE_DIR)/curl $(PUBLIC_INCLUDE_DIR)/openssl \
	   $(PUBLIC_INCLUDE_DIR)/AltivecCore/
	touch $@

verify-mac: $(PUBLIC_LIBS)
	@echo "--- Verifying Mac AltivecCore static libraries ---"
	@missing=0; \
	for lib in $(PUBLIC_LIBS); do \
		info="`$(LIPO) -info $$lib 2>/dev/null`"; \
		echo "  > $$info"; \
		for arch in ppc i386 x86_64 arm64; do \
			echo "$$info" | grep -qw "$$arch" || { \
				echo " [!] ERROR: $$lib missing $$arch"; \
				missing=1; \
			}; \
		done; \
	done; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _curl_easy_init' || { echo " [!] ERROR: aggregate missing _curl_easy_init (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _sqlite3_open' || { echo " [!] ERROR: aggregate missing _sqlite3_open (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _cJSON_Parse' || { echo " [!] ERROR: aggregate missing _cJSON_Parse (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q '_OBJC_CLASS_$$_AltivecCore' || { echo " [!] ERROR: aggregate missing AltivecCore class (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=ppc $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _curl_easy_init' || { echo " [!] ERROR: aggregate missing _curl_easy_init (ppc)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=ppc $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _sqlite3_open' || { echo " [!] ERROR: aggregate missing _sqlite3_open (ppc)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=ppc $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _cJSON_Parse' || { echo " [!] ERROR: aggregate missing _cJSON_Parse (ppc)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=ppc $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q '.objc_class_name_AltivecCore' || { echo " [!] ERROR: aggregate missing AltivecCore class (ppc)"; missing=1; }; \
	exit $$missing

$(INTERMEDIATE)/c-exports.txt: $(PUBLIC_COMPONENT_LIBS)
	@echo "--- Extracting AltivecCore public C exports (intersection of all 4 arches) ---"
	mkdir -p $(INTERMEDIATE)
	{ \
	  for arch in ppc i386 x86_64 arm64; do \
	    { \
	      $(NM) -gm --defined-only --extern-only --arch=$$arch $(PUBLIC_LIB_DIR)/libcurl.a 2>/dev/null \
	        | awk '!/private external/ && / external / && $$NF ~ /^_curl_/ {print $$NF}'; \
	      $(NM) -gm --defined-only --extern-only --arch=$$arch $(PUBLIC_LIB_DIR)/libssl.a 2>/dev/null \
	        | awk '!/private external/ && / external / && $$NF ~ /^_[A-Za-z]/ {print $$NF}'; \
	      $(NM) -gm --defined-only --extern-only --arch=$$arch $(PUBLIC_LIB_DIR)/libcrypto.a 2>/dev/null \
	        | awk '!/private external/ && / external / && $$NF ~ /^_[A-Za-z]/ && $$NF != "_OPENSSL_armcap_P" {print $$NF}'; \
	      $(NM) -gm --defined-only --extern-only --arch=$$arch $(PUBLIC_LIB_DIR)/libz.a 2>/dev/null \
	        | awk '!/private external/ && / external / && $$NF ~ /^_[A-Za-z]/ {print $$NF}'; \
	      $(NM) -gm --defined-only --extern-only --arch=$$arch $(PUBLIC_LIB_DIR)/libsqlite3.a 2>/dev/null \
	        | awk '!/private external/ && / external / && $$NF ~ /^_sqlite3_/ {print $$NF}'; \
	      $(NM) -gm --defined-only --extern-only --arch=$$arch $(PUBLIC_LIB_DIR)/libcjson.a 2>/dev/null \
	        | awk '!/private external/ && / external / && $$NF ~ /^_cJSON/ {print $$NF}'; \
	    } | sort -u; \
	  done; \
	} | sort | uniq -c | awk '$$1 == 4 {print $$2}' > $@

$(INTERMEDIATE)/exports-legacy.txt: $(INTERMEDIATE)/c-exports.txt
	cp $< $@
	echo '.objc_class_name_AltivecCore' >> $@
	echo '.objc_class_name_AICURLConnection' >> $@
	echo '.objc_class_name_AIHTTPURLResponse' >> $@

$(INTERMEDIATE)/exports-modern.txt: $(INTERMEDIATE)/c-exports.txt
	cp $< $@
	echo '_OBJC_CLASS_$$_AltivecCore' >> $@
	echo '_OBJC_METACLASS_$$_AltivecCore' >> $@
	echo '_OBJC_CLASS_$$_AICURLConnection' >> $@
	echo '_OBJC_METACLASS_$$_AICURLConnection' >> $@
	echo '_OBJC_CLASS_$$_AIHTTPURLResponse' >> $@
	echo '_OBJC_METACLASS_$$_AIHTTPURLResponse' >> $@

$(INTERMEDIATE)/AltivecCore-ppc.dylib: $(INTERMEDIATE)/exports-legacy.txt $(PUBLIC_LIBS)
