$(STAMP_DIR)/cjson-x64.done: $(CJSON_DIR)/cJSON.c $(CJSON_DIR)/cJSON_Utils.c \
                              $(CJSON_DIR)/cJSON.h $(CJSON_DIR)/cJSON_Utils.h
	@echo "--- Building cJSON (x86_64) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/x64/lib $(STAMP_DIR)
	$(COMPILER_X64) $(X64_COMPILE_FLAGS) $(CJSON_CFLAGS) \
