$(INTERMEDIATE)/AltivecCore-arm64.dylib: $(INTERMEDIATE)/exports-modern.txt $(PUBLIC_LIBS)
	@echo "--- Linking AltivecCore dylib (arm64) ---"
	$(COMPILER_ARM64) \
	  $(ARM64_FLAGS) $(DYLIB_LINK_FLAGS) \
	  -Wl,-exported_symbols_list,$(INTERMEDIATE)/exports-modern.txt \
	  -Wl,-force_load,$(PUBLIC_LIB_DIR)/libAltivecCore.a \
	  -framework Foundation -framework CoreFoundation -framework SystemConfiguration \
	  -o $@

$(INTERMEDIATE)/AltivecCore.dylib: $(INTERMEDIATE)/AltivecCore-ppc.dylib \
                                   $(INTERMEDIATE)/AltivecCore-x86.dylib \
                                   $(INTERMEDIATE)/AltivecCore-x64.dylib \
                                   $(INTERMEDIATE)/AltivecCore-arm64.dylib
	@echo "--- Merging Quad-Fat AltivecCore dylib ---"
	$(LIPO) -create $^ -output $@

$(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME): $(INTERMEDIATE)/AltivecCore.dylib \
                                      $(FRAMEWORK_INFO_PLIST) \
                                      $(PUBLIC_LIB_DIR)/cacert.pem \
                                      $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Assembling AltivecCore.framework bundle ---"
	rm -rf $(FRAMEWORK_BUNDLE)
	mkdir -p $(FRAMEWORK_VERSION_DIR)/Headers $(FRAMEWORK_VERSION_DIR)/Resources
	cp $(INTERMEDIATE)/AltivecCore.dylib $(FRAMEWORK_VERSION_DIR)/$(FRAMEWORK_NAME)
	cp $(FRAMEWORK_INFO_PLIST) $(FRAMEWORK_VERSION_DIR)/Resources/Info.plist
	cp $(PUBLIC_LIB_DIR)/cacert.pem $(FRAMEWORK_VERSION_DIR)/Resources/cacert.pem
	cp -R $(PUBLIC_INCLUDE_DIR)/* $(FRAMEWORK_VERSION_DIR)/Headers/
	ln -sf $(FRAMEWORK_VERSION) $(FRAMEWORK_BUNDLE)/Versions/Current
	ln -sf Versions/Current/$(FRAMEWORK_NAME) $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME)
	ln -sf Versions/Current/Headers $(FRAMEWORK_BUNDLE)/Headers
	ln -sf Versions/Current/Resources $(FRAMEWORK_BUNDLE)/Resources

verify-dynamic: $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME)
	@echo "--- Verifying AltivecCore.framework ---"
	@info="`$(LIPO) -info $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null`"; \
	echo "  > $$info"; \
	missing=0; \
	for arch in ppc i386 x86_64 arm64; do \
		echo "$$info" | grep -qw "$$arch" || { \
			echo " [!] ERROR: AltivecCore missing $$arch"; \
			missing=1; \
		}; \
	done; \
	test -L $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) || { echo " [!] ERROR: top-level binary symlink missing"; missing=1; }; \
	test -L $(FRAMEWORK_BUNDLE)/Headers || { echo " [!] ERROR: Headers symlink missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Resources/Info.plist || { echo " [!] ERROR: Info.plist missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Resources/cacert.pem || { echo " [!] ERROR: cacert.pem missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Headers/AltivecCore.h || { echo " [!] ERROR: AltivecCore.h umbrella missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Headers/AICURLConnection.h || { echo " [!] ERROR: AICURLConnection.h missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Headers/sqlite3.h || { echo " [!] ERROR: sqlite3.h missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Headers/cJSON.h || { echo " [!] ERROR: cJSON.h missing"; missing=1; }; \
	test -d $(FRAMEWORK_VERSION_DIR)/Headers/curl || { echo " [!] ERROR: curl/ headers missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Headers/openssl/ssl.h || { echo " [!] ERROR: openssl/ headers missing"; missing=1; }; \
	test -f $(FRAMEWORK_VERSION_DIR)/Headers/zlib.h || { echo " [!] ERROR: zlib.h missing"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q ' T _SSL_new' || { echo " [!] ERROR: _SSL_new not exported"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q ' T _deflate' || { echo " [!] ERROR: _deflate not exported"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q ' T _curl_easy_init' || { echo " [!] ERROR: _curl_easy_init not exported"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q ' T _sqlite3_open' || { echo " [!] ERROR: _sqlite3_open not exported"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q ' T _cJSON_Parse' || { echo " [!] ERROR: _cJSON_Parse not exported"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q '_OBJC_CLASS_$$_AltivecCore' || { echo " [!] ERROR: AltivecCore class not exported (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q '_OBJC_CLASS_$$_AIHTTPURLResponse' || { echo " [!] ERROR: AIHTTPURLResponse class not exported (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=ppc $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q '.objc_class_name_AltivecCore' || { echo " [!] ERROR: AltivecCore class not exported (ppc)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=ppc $(FRAMEWORK_BUNDLE)/$(FRAMEWORK_NAME) 2>/dev/null | grep -q '.objc_class_name_AIHTTPURLResponse' || { echo " [!] ERROR: AIHTTPURLResponse class not exported (ppc)"; missing=1; }; \
	exit $$missing

prune-build-files:
	@echo "--- Pruning Mac AltivecCore build intermediates ---"
	rm -rf $(INTERMEDIATE) $(PREFIX) $(STAMP_DIR)

clean:
	rm -rf $(BUILD_ROOT)

.PHONY: all static dynamic curl-ready sqlite-ready verify-mac verify-dynamic prune-build-files clean
