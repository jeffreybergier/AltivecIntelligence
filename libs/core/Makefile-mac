	  -Wl,-force_load,$(PUBLIC_LIB_DIR)/libAltivecCore.a \
	  -framework Foundation -framework CoreFoundation -framework SystemConfiguration \
	  -o $@

$(INTERMEDIATE)/AltivecCore-x64.dylib: $(INTERMEDIATE)/exports-modern.txt $(PUBLIC_LIBS)
	@echo "--- Linking AltivecCore dylib (x86_64) ---"
	$(COMPILER_X64) \
	  $(X64_FLAGS) $(DYLIB_LINK_FLAGS) \
	  -Wl,-exported_symbols_list,$(INTERMEDIATE)/exports-modern.txt \
	  -Wl,-force_load,$(PUBLIC_LIB_DIR)/libAltivecCore.a \
	  -framework Foundation -framework CoreFoundation -framework SystemConfiguration \
