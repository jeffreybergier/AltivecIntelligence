	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_PPC) $(COMPILER_PPC) \
	  $(PPC_FLAGS) $(DYLIB_LINK_FLAGS) \
	  -Wl,-exported_symbols_list,$(INTERMEDIATE)/exports-legacy.txt \
	  -Wl,-force_load,$(PUBLIC_LIB_DIR)/libAltivecCore.a \
	  -framework Foundation -framework CoreFoundation -framework SystemConfiguration \
	  -o $@

