include core_common.mk

CWD=$(shell pwd)
BUILD_ROOT=$(CWD)/build-phone
INTERMEDIATE=$(BUILD_ROOT)/intermediate
PREFIX=$(BUILD_ROOT)/prefix
STAMP_DIR=$(BUILD_ROOT)/stamps
PUBLIC_LIB_DIR=$(BUILD_ROOT)/lib
PUBLIC_INCLUDE_DIR=$(BUILD_ROOT)/include

CURL_DIR ?= $(CWD)/../libcurl/build-phone
SQLITE_DIR ?= $(CWD)/../sqlite/build-phone
CJSON_DIR=third_party/cJSON

IOS_V7_FLAGS=-target armv7-apple-ios$(IOS_MIN_VER) -isysroot $(SDK_IOS_PATH) -arch armv7 -B$(BIN_DIR)
IOS_64_FLAGS=-target arm64-apple-ios$(IOS_ARM64_MIN_VER) -isysroot $(SDK_IOS_PATH) -arch arm64 -B$(BIN_DIR)
CJSON_CFLAGS=$(OPT_FLAGS) $(COMMON_WARN_FLAGS) -std=c99 -I$(CJSON_DIR)

CORE_COMPONENT_LIBS=libAICURLConnection.a \
                    libcurl.a \
                    libssl.a \
                    libcrypto.a \
                    libz.a \
                    libsqlite3.a \
                    libcjson.a
CORE_STATIC_LIBS=libAltivecCore.a $(CORE_COMPONENT_LIBS)
PUBLIC_LIBS=$(addprefix $(PUBLIC_LIB_DIR)/,$(CORE_STATIC_LIBS))
CURL_PUBLIC_FILES=libAICURLConnection.a \
                  libcurl.a \
                  libssl.a \
                  libcrypto.a \
                  libz.a \
                  cacert.pem
SQLITE_PUBLIC_FILES=libsqlite3.a
CORE_INPUTS_ARMV7=$(INTERMEDIATE)/thin/armv7/libAltivecCoreWrapper.a \
                  $(addprefix $(INTERMEDIATE)/thin/armv7/,$(CORE_COMPONENT_LIBS))
CORE_INPUTS_ARM64=$(INTERMEDIATE)/thin/arm64/libAltivecCoreWrapper.a \
                  $(addprefix $(INTERMEDIATE)/thin/arm64/,$(CORE_COMPONENT_LIBS))

REMOVED_FRAMEWORK_BUNDLE=$(PUBLIC_LIB_DIR)/AltivecCore.framework

all: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem \
     $(PUBLIC_INCLUDE_DIR)/.stamp verify-phone
	@rm -rf $(REMOVED_FRAMEWORK_BUNDLE)
	@echo "-----------------------------------------------------------"
	@echo "PHONE ALTIVECCORE STATIC LIBS BUILD SUCCESSFUL"
	@echo "Libraries: $(PUBLIC_LIB_DIR)"
	@echo "Headers:   $(PUBLIC_INCLUDE_DIR)"
	@echo "-----------------------------------------------------------"
	@$(MAKE) --no-print-directory -f Makefile-phone prune-build-files

static: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem \
        $(PUBLIC_INCLUDE_DIR)/.stamp verify-phone
	@rm -rf $(REMOVED_FRAMEWORK_BUNDLE)
	@echo "-----------------------------------------------------------"
	@echo "PHONE ALTIVECCORE STATIC LIBS BUILD SUCCESSFUL"
	@echo "Libraries: $(PUBLIC_LIB_DIR)"
	@echo "Headers:   $(PUBLIC_INCLUDE_DIR)"
	@echo "-----------------------------------------------------------"
	@$(MAKE) --no-print-directory -f Makefile-phone prune-build-files

dynamic:
	@echo " [!] ERROR: iOS AltivecCore.framework is no longer supported."
	@echo "     Use static linkage for iOS 4.3-7 compatibility."
	@exit 1

curl-ready:
	@if [ ! -f "$(CURL_DIR)/lib/libAICURLConnection.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libcurl.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libssl.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libcrypto.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/libz.a" ] || \
	    [ ! -f "$(CURL_DIR)/lib/cacert.pem" ] || \
	    [ ! -f "$(CURL_DIR)/include/AICURLConnection.h" ]; then \
		echo "--- Building Phone libcurl static dependency ---"; \
		$(MAKE) -C $(CWD)/../libcurl phone-static; \
	fi

sqlite-ready:
	@if [ ! -f "$(SQLITE_DIR)/lib/libsqlite3.a" ] || \
	    [ ! -f "$(SQLITE_DIR)/include/sqlite3.h" ]; then \
		echo "--- Building Phone SQLite static dependency ---"; \
		$(MAKE) -C $(CWD)/../sqlite phone; \
	fi

$(addprefix $(PUBLIC_LIB_DIR)/,$(CURL_PUBLIC_FILES)): $(PUBLIC_LIB_DIR)/%: | curl-ready
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $(CURL_DIR)/lib/$* $@

$(addprefix $(PUBLIC_LIB_DIR)/,$(SQLITE_PUBLIC_FILES)): $(PUBLIC_LIB_DIR)/%: | sqlite-ready
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $(SQLITE_DIR)/lib/$* $@

define thin_component_rule
$(INTERMEDIATE)/thin/$1/%.a: $(PUBLIC_LIB_DIR)/%.a
	mkdir -p $$(dir $$@)
	$(LIPO_MODERN) $$< -thin $2 -output $$@
endef

$(eval $(call thin_component_rule,armv7,armv7))
$(eval $(call thin_component_rule,arm64,arm64))

$(INTERMEDIATE)/thin/armv7/libAltivecCoreWrapper.a: AltivecCore.m \
                                                    AltivecCore.h \
                                                    $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Building AltivecCore wrapper (armv7) ---"
	mkdir -p $(INTERMEDIATE) $(INTERMEDIATE)/thin/armv7
	$(COMPILER_IOS) $(IOS_V7_FLAGS) $(OPT_FLAGS) $(COMMON_WARN_FLAGS) \
	  -I$(PUBLIC_INCLUDE_DIR) -c AltivecCore.m \
	  -o $(INTERMEDIATE)/AltivecCore-armv7.o
	$(AR_MODERN) rc $@ \
	  $(INTERMEDIATE)/AltivecCore-armv7.o
	$(RANLIB_MODERN) $@

$(INTERMEDIATE)/thin/arm64/libAltivecCoreWrapper.a: AltivecCore.m \
                                                    AltivecCore.h \
                                                    $(PUBLIC_INCLUDE_DIR)/.stamp
	@echo "--- Building AltivecCore wrapper (arm64) ---"
	mkdir -p $(INTERMEDIATE) $(INTERMEDIATE)/thin/arm64
	$(COMPILER_IOS) $(IOS_64_FLAGS) $(OPT_FLAGS) $(COMMON_WARN_FLAGS) \
	  -I$(PUBLIC_INCLUDE_DIR) -c AltivecCore.m \
	  -o $(INTERMEDIATE)/AltivecCore-arm64.o
	$(AR_MODERN) rc $@ \
	  $(INTERMEDIATE)/AltivecCore-arm64.o
	$(RANLIB_MODERN) $@

$(PREFIX)/armv7/lib/libAltivecCore.a: $(CORE_INPUTS_ARMV7)
	@echo "--- Aggregating AltivecCore static archive (armv7) ---"
	mkdir -p $(PREFIX)/armv7/lib
	$(LIBTOOL_MODERN) -static --no_warning_for_no_symbols -o $@ $^

$(PREFIX)/arm64/lib/libAltivecCore.a: $(CORE_INPUTS_ARM64)
	@echo "--- Aggregating AltivecCore static archive (arm64) ---"
	mkdir -p $(PREFIX)/arm64/lib
	$(LIBTOOL_MODERN) -static --no_warning_for_no_symbols -o $@ $^

$(PREFIX)/lib/libAltivecCore.a: $(PREFIX)/armv7/lib/libAltivecCore.a \
                                $(PREFIX)/arm64/lib/libAltivecCore.a
	mkdir -p $(PREFIX)/lib
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libAltivecCore.a \
	  $(PREFIX)/armv7/lib/libAltivecCore.a \
	  -output $@

$(PUBLIC_LIB_DIR)/libAltivecCore.a: $(PREFIX)/lib/libAltivecCore.a
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(STAMP_DIR)/cjson-armv7: $(CJSON_DIR)/cJSON.c $(CJSON_DIR)/cJSON_Utils.c \
                           $(CJSON_DIR)/cJSON.h $(CJSON_DIR)/cJSON_Utils.h
	@echo "--- Building cJSON (armv7) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/armv7/lib $(STAMP_DIR)
	$(COMPILER_IOS) $(IOS_V7_FLAGS) $(CJSON_CFLAGS) \
	  -c $(CJSON_DIR)/cJSON.c \
	  -o $(INTERMEDIATE)/cJSON-armv7.o
	$(COMPILER_IOS) $(IOS_V7_FLAGS) $(CJSON_CFLAGS) \
	  -c $(CJSON_DIR)/cJSON_Utils.c \
	  -o $(INTERMEDIATE)/cJSON_Utils-armv7.o
	$(AR_MODERN) rc $(PREFIX)/armv7/lib/libcjson.a \
	  $(INTERMEDIATE)/cJSON-armv7.o $(INTERMEDIATE)/cJSON_Utils-armv7.o
	$(RANLIB_MODERN) $(PREFIX)/armv7/lib/libcjson.a
	touch $@

$(STAMP_DIR)/cjson-arm64: $(CJSON_DIR)/cJSON.c $(CJSON_DIR)/cJSON_Utils.c \
                           $(CJSON_DIR)/cJSON.h $(CJSON_DIR)/cJSON_Utils.h
	@echo "--- Building cJSON (arm64) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/arm64/lib $(STAMP_DIR)
	$(COMPILER_IOS) $(IOS_64_FLAGS) $(CJSON_CFLAGS) \
	  -c $(CJSON_DIR)/cJSON.c \
	  -o $(INTERMEDIATE)/cJSON-arm64.o
	$(COMPILER_IOS) $(IOS_64_FLAGS) $(CJSON_CFLAGS) \
	  -c $(CJSON_DIR)/cJSON_Utils.c \
	  -o $(INTERMEDIATE)/cJSON_Utils-arm64.o
	$(AR_MODERN) rc $(PREFIX)/arm64/lib/libcjson.a \
	  $(INTERMEDIATE)/cJSON-arm64.o $(INTERMEDIATE)/cJSON_Utils-arm64.o
	$(RANLIB_MODERN) $(PREFIX)/arm64/lib/libcjson.a
	touch $@

$(PREFIX)/lib/libcjson.a: $(STAMP_DIR)/cjson-armv7 \
                           $(STAMP_DIR)/cjson-arm64
	mkdir -p $(PREFIX)/lib
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libcjson.a \
	  $(PREFIX)/armv7/lib/libcjson.a \
	  -output $@

$(PUBLIC_LIB_DIR)/libcjson.a: $(PREFIX)/lib/libcjson.a
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(PUBLIC_INCLUDE_DIR)/.stamp: AltivecCore.h | curl-ready sqlite-ready
	mkdir -p $(PUBLIC_INCLUDE_DIR)
	rm -rf $(PUBLIC_INCLUDE_DIR)/curl $(PUBLIC_INCLUDE_DIR)/openssl \
	       $(PUBLIC_INCLUDE_DIR)/AltivecCore
	cp -R $(CURL_DIR)/include/* $(PUBLIC_INCLUDE_DIR)/
	rm -f $(PUBLIC_INCLUDE_DIR)/AltivecCURL.h
	cp $(SQLITE_DIR)/include/sqlite3.h $(PUBLIC_INCLUDE_DIR)/
	cp $(CJSON_DIR)/cJSON.h $(PUBLIC_INCLUDE_DIR)/
	cp $(CJSON_DIR)/cJSON_Utils.h $(PUBLIC_INCLUDE_DIR)/
	cp AltivecCore.h $(PUBLIC_INCLUDE_DIR)/
	mkdir -p $(PUBLIC_INCLUDE_DIR)/AltivecCore
	cp $(PUBLIC_INCLUDE_DIR)/AltivecCore.h \
	   $(PUBLIC_INCLUDE_DIR)/AICURLConnection.h \
	   $(PUBLIC_INCLUDE_DIR)/zlib.h \
	   $(PUBLIC_INCLUDE_DIR)/sqlite3.h \
	   $(PUBLIC_INCLUDE_DIR)/cJSON.h \
	   $(PUBLIC_INCLUDE_DIR)/cJSON_Utils.h \
	   $(PUBLIC_INCLUDE_DIR)/AltivecCore/
	cp -R $(PUBLIC_INCLUDE_DIR)/curl $(PUBLIC_INCLUDE_DIR)/openssl \
	   $(PUBLIC_INCLUDE_DIR)/AltivecCore/
	touch $@

verify-phone: $(PUBLIC_LIBS)
	@echo "--- Verifying Phone AltivecCore static libraries ---"
	@missing=0; \
	for lib in $(PUBLIC_LIBS); do \
		info="`$(LIPO_MODERN) -info $$lib 2>/dev/null`"; \
		echo "  > $$info"; \
		for arch in armv7 arm64; do \
			echo "$$info" | grep -qw "$$arch" || { \
				echo " [!] ERROR: $$lib missing $$arch"; \
				missing=1; \
			}; \
		done; \
	done; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _curl_easy_init' || { echo " [!] ERROR: aggregate missing _curl_easy_init (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _sqlite3_open' || { echo " [!] ERROR: aggregate missing _sqlite3_open (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q ' T _cJSON_Parse' || { echo " [!] ERROR: aggregate missing _cJSON_Parse (arm64)"; missing=1; }; \
	$(NM) --defined-only --extern-only --arch=arm64 $(PUBLIC_LIB_DIR)/libAltivecCore.a 2>/dev/null | grep -q '_OBJC_CLASS_$$_AltivecCore' || { echo " [!] ERROR: aggregate missing AltivecCore class (arm64)"; missing=1; }; \
	exit $$missing

prune-build-files:
	@echo "--- Pruning Phone AltivecCore build intermediates ---"
	rm -rf $(INTERMEDIATE) $(PREFIX) $(STAMP_DIR)

clean:
	rm -rf $(BUILD_ROOT)

.PHONY: all static dynamic curl-ready sqlite-ready verify-phone prune-build-files clean
