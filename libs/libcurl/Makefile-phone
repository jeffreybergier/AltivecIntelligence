include libcurl_common.mk

ZLIB_VER=1.2.13
OPENSSL_VER=1.1.1w
CURL_VER=7.88.1

CWD=$(shell pwd)
BUILD_ROOT=$(CWD)/build-phone
INTERMEDIATE=$(BUILD_ROOT)/intermediate
PREFIX=$(BUILD_ROOT)/prefix
STAMP_DIR=$(BUILD_ROOT)/stamps
PUBLIC_LIB_DIR=$(BUILD_ROOT)/lib
PUBLIC_INCLUDE_DIR=$(BUILD_ROOT)/include
TARBALL_DIR=tarballs

ZLIB_URL=https://zlib.net/fossils/zlib-$(ZLIB_VER).tar.gz
OPENSSL_URL=https://www.openssl.org/source/openssl-$(OPENSSL_VER).tar.gz
CURL_URL=https://curl.se/download/curl-$(CURL_VER).tar.gz

IOS_ARM64_MIN_VER=7.0
IOS_V7_FLAGS=-target armv7-apple-ios$(IOS_MIN_VER) -isysroot $(SDK_IOS_PATH) -arch armv7 -B$(BIN_DIR)
IOS_64_FLAGS=-target arm64-apple-ios$(IOS_ARM64_MIN_VER) -isysroot $(SDK_IOS_PATH) -arch arm64 -B$(BIN_DIR)
OPENSSL_CFLAGS=-Wno-overriding-t-option

ZLIB_TARBALL=$(TARBALL_DIR)/zlib-$(ZLIB_VER).tar.gz
OPENSSL_TARBALL=$(TARBALL_DIR)/openssl-$(OPENSSL_VER).tar.gz
CURL_TARBALL=$(TARBALL_DIR)/curl-$(CURL_VER).tar.gz

ZLIB_ARMV7_SRC=$(INTERMEDIATE)/zlib-$(ZLIB_VER)-armv7
ZLIB_ARM64_SRC=$(INTERMEDIATE)/zlib-$(ZLIB_VER)-arm64
OPENSSL_ARMV7_SRC=$(INTERMEDIATE)/openssl-$(OPENSSL_VER)-armv7
OPENSSL_ARM64_SRC=$(INTERMEDIATE)/openssl-$(OPENSSL_VER)-arm64
CURL_ARMV7_SRC=$(INTERMEDIATE)/curl-$(CURL_VER)-armv7
CURL_ARM64_SRC=$(INTERMEDIATE)/curl-$(CURL_VER)-arm64

PUBLIC_LIBS=$(PUBLIC_LIB_DIR)/libAICURLConnection.a \
            $(PUBLIC_LIB_DIR)/libcurl.a \
            $(PUBLIC_LIB_DIR)/libssl.a \
            $(PUBLIC_LIB_DIR)/libcrypto.a \
            $(PUBLIC_LIB_DIR)/libz.a

all: static

static: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem \
        $(PUBLIC_INCLUDE_DIR)/.stamp verify-phone prune-build-files
	@echo "-----------------------------------------------------------"
	@echo "PHONE UNIVERSAL (armv7 + arm64) BUILD SUCCESSFUL"
	@echo "Libraries: $(PUBLIC_LIB_DIR)"
	@echo "Headers:   $(PUBLIC_INCLUDE_DIR)"
	@echo "-----------------------------------------------------------"

aicc: $(PUBLIC_LIB_DIR)/libAICURLConnection.a \
      $(PUBLIC_INCLUDE_DIR)/AICURLConnection.h verify-phone prune-build-files
	@echo "AICURLConnection build successful."

verify-phone: $(PUBLIC_LIBS)
	@echo "--- Verifying Phone universal libraries ---"
	@for lib in $^; do \
	  info="$$($(LIPO_MODERN) -info "$$lib")"; \
	  echo "  > $$info"; \
	  echo "$$info" | grep -q 'armv7' || exit 1; \
	  echo "$$info" | grep -q 'arm64' || exit 1; \
	done

prune-build-files:
	@echo "--- Pruning Phone build intermediates ---"
	rm -rf $(INTERMEDIATE) $(PREFIX) $(STAMP_DIR)

$(TARBALL_DIR):
	mkdir -p $@

$(ZLIB_TARBALL): | $(TARBALL_DIR)
	curl -fL $(ZLIB_URL) -o $@

$(OPENSSL_TARBALL): | $(TARBALL_DIR)
	curl -fL $(OPENSSL_URL) -o $@

$(CURL_TARBALL): | $(TARBALL_DIR)
	curl -fL $(CURL_URL) -o $@

$(TARBALL_DIR)/cacert.pem: | $(TARBALL_DIR)
	curl -fL https://curl.se/ca/cacert.pem -o $@

$(PUBLIC_LIB_DIR)/cacert.pem: $(TARBALL_DIR)/cacert.pem
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(STAMP_DIR)/zlib-armv7-source: $(ZLIB_TARBALL)
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $(ZLIB_ARMV7_SRC)
	mkdir -p $(ZLIB_ARMV7_SRC)
	tar -xf $< -C $(ZLIB_ARMV7_SRC) --strip-components=1
	touch $@

$(STAMP_DIR)/zlib-arm64-source: $(ZLIB_TARBALL)
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $(ZLIB_ARM64_SRC)
	mkdir -p $(ZLIB_ARM64_SRC)
	tar -xf $< -C $(ZLIB_ARM64_SRC) --strip-components=1
	touch $@

$(STAMP_DIR)/zlib-armv7: $(STAMP_DIR)/zlib-armv7-source
	@echo "--- Building zlib (armv7) ---"
	cd $(ZLIB_ARMV7_SRC) && \
	./configure --static --prefix=$(PREFIX)/armv7 && \
	sed -i 's|^CC=.*|CC=$(COMPILER_IOS) $(IOS_V7_FLAGS)|g' Makefile && \
	sed -i 's|^CFLAGS=.*|CFLAGS=$(OPT_FLAGS)|g' Makefile && \
	sed -i 's|^AR=.*|AR=$(AR_MODERN)|g' Makefile && \
	sed -i 's|^RANLIB=.*|RANLIB=$(RANLIB_MODERN)|g' Makefile && \
	make -j$(JOBS) ARFLAGS="rc" install
	touch $@

$(STAMP_DIR)/zlib-arm64: $(STAMP_DIR)/zlib-arm64-source
	@echo "--- Building zlib (arm64) ---"
	cd $(ZLIB_ARM64_SRC) && \
	./configure --static --prefix=$(PREFIX)/arm64 && \
	sed -i 's|^CC=.*|CC=$(COMPILER_IOS) $(IOS_64_FLAGS)|g' Makefile && \
	sed -i 's|^CFLAGS=.*|CFLAGS=$(OPT_FLAGS)|g' Makefile && \
	sed -i 's|^AR=.*|AR=$(AR_MODERN)|g' Makefile && \
	sed -i 's|^RANLIB=.*|RANLIB=$(RANLIB_MODERN)|g' Makefile && \
	make -j$(JOBS) ARFLAGS="rc" install
	touch $@

$(STAMP_DIR)/zlib-universal: $(STAMP_DIR)/zlib-armv7 $(STAMP_DIR)/zlib-arm64
	mkdir -p $(PREFIX)/lib $(PREFIX)/include
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libz.a \
	  $(PREFIX)/armv7/lib/libz.a \
	  -output $(PREFIX)/lib/libz.a
	cp $(PREFIX)/arm64/include/*.h $(PREFIX)/include/
	touch $@

$(PREFIX)/lib/libz.a: $(STAMP_DIR)/zlib-universal
	test -f $@

$(STAMP_DIR)/openssl-armv7-source: $(OPENSSL_TARBALL)
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $(OPENSSL_ARMV7_SRC)
	mkdir -p $(OPENSSL_ARMV7_SRC)
	tar -xf $< -C $(OPENSSL_ARMV7_SRC) --strip-components=1
	touch $@

$(STAMP_DIR)/openssl-arm64-source: $(OPENSSL_TARBALL)
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $(OPENSSL_ARM64_SRC)
	mkdir -p $(OPENSSL_ARM64_SRC)
	tar -xf $< -C $(OPENSSL_ARM64_SRC) --strip-components=1
	touch $@

$(STAMP_DIR)/openssl-armv7: $(STAMP_DIR)/openssl-armv7-source \
                            | $(PREFIX)/lib/libz.a
	@echo "--- Building OpenSSL (armv7) ---"
	cd $(OPENSSL_ARMV7_SRC) && \
	./Configure ios-cross no-shared no-tests no-zlib \
	--prefix=$(PREFIX)/armv7 \
CC="$(COMPILER_IOS)" AR="$(AR_MODERN)" RANLIB="$(RANLIB_MODERN)" \
CFLAGS="$(IOS_V7_FLAGS) -mfpu=neon $(OPT_FLAGS) $(OPENSSL_CFLAGS)" && \
	make -j$(JOBS) build_libs && make install_dev
	touch $@

$(STAMP_DIR)/openssl-arm64: $(STAMP_DIR)/openssl-arm64-source \
                            | $(PREFIX)/lib/libz.a
	@echo "--- Building OpenSSL (arm64) ---"
	cd $(OPENSSL_ARM64_SRC) && \
	./Configure ios64-cross no-shared no-tests no-zlib \
	--prefix=$(PREFIX)/arm64 \
CC="$(COMPILER_IOS)" AR="$(AR_MODERN)" RANLIB="$(RANLIB_MODERN)" \
CFLAGS="$(IOS_64_FLAGS) $(OPT_FLAGS) $(OPENSSL_CFLAGS)" && \
	make -j$(JOBS) build_libs && make install_dev
	touch $@

$(STAMP_DIR)/openssl-universal: $(STAMP_DIR)/openssl-armv7 \
                                $(STAMP_DIR)/openssl-arm64
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libssl.a \
	  $(PREFIX)/armv7/lib/libssl.a \
	  -output $(PREFIX)/lib/libssl.a
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libcrypto.a \
	  $(PREFIX)/armv7/lib/libcrypto.a \
	  -output $(PREFIX)/lib/libcrypto.a
	mkdir -p $(PREFIX)/include/openssl
	cp -R $(PREFIX)/arm64/include/openssl/* $(PREFIX)/include/openssl/
	touch $@

$(PREFIX)/lib/libssl.a $(PREFIX)/lib/libcrypto.a: \
    $(STAMP_DIR)/openssl-universal
	test -f $@

$(STAMP_DIR)/curl-armv7-source: $(CURL_TARBALL)
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $(CURL_ARMV7_SRC)
	mkdir -p $(CURL_ARMV7_SRC)
	tar -xf $< -C $(CURL_ARMV7_SRC) --strip-components=1
	touch $@

$(STAMP_DIR)/curl-arm64-source: $(CURL_TARBALL)
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $(CURL_ARM64_SRC)
	mkdir -p $(CURL_ARM64_SRC)
	tar -xf $< -C $(CURL_ARM64_SRC) --strip-components=1
	touch $@

$(STAMP_DIR)/curl-armv7: $(STAMP_DIR)/curl-armv7-source \
                         | $(PREFIX)/lib/libz.a \
                           $(PREFIX)/lib/libssl.a \
                           $(PREFIX)/lib/libcrypto.a
	@echo "--- Building curl (armv7) ---"
	cd $(CURL_ARMV7_SRC) && \
	CC="$(COMPILER_IOS) $(IOS_V7_FLAGS)" \
	AR="$(AR_MODERN)" RANLIB="$(RANLIB_MODERN)" \
	CFLAGS="$(OPT_FLAGS) $(COMMON_WARN_FLAGS)" \
	CPPFLAGS="-I$(PREFIX)/armv7/include" \
	LDFLAGS="-L$(PREFIX)/armv7/lib" \
LIBS="-lresolv" \
	curl_cv_sizeof_size_t=4 \
	curl_cv_getaddrinfo_threadsafe=yes \
	./configure --host=arm-apple-darwin \
	--disable-shared --enable-static \
	--with-openssl=$(PREFIX)/armv7 \
	--with-zlib=$(PREFIX)/armv7 \
	--enable-threaded-resolver \
	--disable-alt-svc --disable-hsts \
	--disable-ldap --disable-ldaps \
	--prefix=$(PREFIX)/armv7 && \
	grep -q '^#define HAVE_GETADDRINFO_THREADSAFE 1' lib/curl_config.h \
	  || { echo " [!] armv7: HAVE_GETADDRINFO_THREADSAFE not set"; exit 1; } && \
	make -j$(JOBS) -C lib install && \
	make -j$(JOBS) -C include install
	touch $@

$(STAMP_DIR)/curl-arm64: $(STAMP_DIR)/curl-arm64-source \
                         | $(PREFIX)/lib/libz.a \
                           $(PREFIX)/lib/libssl.a \
                           $(PREFIX)/lib/libcrypto.a
	@echo "--- Building curl (arm64) ---"
	cd $(CURL_ARM64_SRC) && \
	CC="$(COMPILER_IOS) $(IOS_64_FLAGS)" \
	AR="$(AR_MODERN)" RANLIB="$(RANLIB_MODERN)" \
	CFLAGS="$(OPT_FLAGS) $(COMMON_WARN_FLAGS)" \
	CPPFLAGS="-I$(PREFIX)/arm64/include" \
	LDFLAGS="-L$(PREFIX)/arm64/lib" \
LIBS="-lresolv" \
	curl_cv_sizeof_size_t=8 \
	curl_cv_getaddrinfo_threadsafe=yes \
	./configure --host=arm-apple-darwin \
	--disable-shared --enable-static \
	--with-openssl=$(PREFIX)/arm64 \
	--with-zlib=$(PREFIX)/arm64 \
	--enable-threaded-resolver \
	--disable-alt-svc --disable-hsts \
	--disable-ldap --disable-ldaps \
	--prefix=$(PREFIX)/arm64 && \
	grep -q '^#define HAVE_GETADDRINFO_THREADSAFE 1' lib/curl_config.h \
	  || { echo " [!] arm64: HAVE_GETADDRINFO_THREADSAFE not set"; exit 1; } && \
	make -j$(JOBS) -C lib install && \
	make -j$(JOBS) -C include install
	touch $@

$(STAMP_DIR)/curl-universal: $(STAMP_DIR)/curl-armv7 \
                             $(STAMP_DIR)/curl-arm64
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libcurl.a \
	  $(PREFIX)/armv7/lib/libcurl.a \
	  -output $(PREFIX)/lib/libcurl.a
	cp -R $(PREFIX)/arm64/include/curl $(PREFIX)/include/
	touch $@

$(PREFIX)/lib/libcurl.a: $(STAMP_DIR)/curl-universal
	test -f $@

$(STAMP_DIR)/aicc-armv7: AICURLConnection.m AICURLConnection.h \
                         | $(PREFIX)/lib/libcurl.a
	@echo "--- Building AICURLConnection (armv7) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/armv7/lib
	$(COMPILER_IOS) $(IOS_V7_FLAGS) $(OPT_FLAGS) \
	  -I$(PREFIX)/armv7/include \
	  -c AICURLConnection.m \
	  -o $(INTERMEDIATE)/AICURLConnection-armv7.o
	$(AR_MODERN) rc \
	  $(PREFIX)/armv7/lib/libAICURLConnection.a \
	  $(INTERMEDIATE)/AICURLConnection-armv7.o
	$(RANLIB_MODERN) $(PREFIX)/armv7/lib/libAICURLConnection.a
	touch $@

$(STAMP_DIR)/aicc-arm64: AICURLConnection.m AICURLConnection.h \
                         | $(PREFIX)/lib/libcurl.a
	@echo "--- Building AICURLConnection (arm64) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/arm64/lib
	$(COMPILER_IOS) $(IOS_64_FLAGS) $(OPT_FLAGS) \
	  -I$(PREFIX)/arm64/include \
	  -c AICURLConnection.m \
	  -o $(INTERMEDIATE)/AICURLConnection-arm64.o
	$(AR_MODERN) rc \
	  $(PREFIX)/arm64/lib/libAICURLConnection.a \
	  $(INTERMEDIATE)/AICURLConnection-arm64.o
	$(RANLIB_MODERN) $(PREFIX)/arm64/lib/libAICURLConnection.a
	touch $@

$(STAMP_DIR)/aicc-universal: $(STAMP_DIR)/aicc-armv7 \
                             $(STAMP_DIR)/aicc-arm64
	$(LIPO_MODERN) -create \
	  $(PREFIX)/arm64/lib/libAICURLConnection.a \
	  $(PREFIX)/armv7/lib/libAICURLConnection.a \
	  -output $(PREFIX)/lib/libAICURLConnection.a
	touch $@

$(PREFIX)/lib/libAICURLConnection.a: $(STAMP_DIR)/aicc-universal
	test -f $@

$(PUBLIC_LIB_DIR)/%.a: $(PREFIX)/lib/%.a
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(PUBLIC_INCLUDE_DIR)/AICURLConnection.h: AICURLConnection.h
	mkdir -p $(PUBLIC_INCLUDE_DIR)
	cp $< $@

$(PUBLIC_INCLUDE_DIR)/.stamp: $(PREFIX)/lib/libcurl.a \
                              $(PREFIX)/lib/libssl.a \
                              $(PREFIX)/lib/libcrypto.a \
                              $(PREFIX)/lib/libz.a \
                              $(PUBLIC_INCLUDE_DIR)/AICURLConnection.h
	mkdir -p $(PUBLIC_INCLUDE_DIR)
	rm -rf $(PUBLIC_INCLUDE_DIR)/curl $(PUBLIC_INCLUDE_DIR)/openssl
	cp -R $(PREFIX)/include/* $(PUBLIC_INCLUDE_DIR)/
	touch $@

clean:
	rm -rf $(BUILD_ROOT)

.PHONY: all static aicc verify-phone prune-build-files clean
