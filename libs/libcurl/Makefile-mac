$(PREFIX)/lib/libAICURLConnection.a: $(STAMP_DIR)/aicc-universal.done
	@test -f $@
	@touch $@

$(PUBLIC_LIB_DIR)/lib%.a: $(PREFIX)/lib/lib%.a
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(PUBLIC_INCLUDE_DIR)/.stamp: $(PREFIX)/lib/libcurl.a \
                              $(PREFIX)/lib/libcrypto.a \
                              $(PREFIX)/lib/libz.a \
                              AICURLConnection.h
	mkdir -p $(PUBLIC_INCLUDE_DIR)
	rm -rf $(PUBLIC_INCLUDE_DIR)/curl $(PUBLIC_INCLUDE_DIR)/openssl
	cp -R $(PREFIX)/include/* $(PUBLIC_INCLUDE_DIR)/
	cp AICURLConnection.h $(PUBLIC_INCLUDE_DIR)/
	touch $@

clean:
	rm -rf $(BUILD_ROOT)

.PHONY: all static aicc aicc-analyze verify-mac prune-build-files clean
