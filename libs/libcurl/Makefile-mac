$(STAMP_DIR)/openssl-universal.done: $(STAMP_DIR)/openssl-ppc.done \
                                       $(STAMP_DIR)/openssl-x86.done \
                                       $(STAMP_DIR)/openssl-x64.done \
                                       $(STAMP_DIR)/openssl-arm64.done
	mkdir -p $(PREFIX)/lib $(PREFIX)/include/openssl
	$(LIPO) -create $(PREFIX)/ppc/lib/libssl.a \
	                 $(PREFIX)/x86/lib/libssl.a \
	                 $(PREFIX)/x64/lib/libssl.a \
	                 $(PREFIX)/arm64/lib/libssl.a \
	                 -output $(PREFIX)/lib/libssl.a
	$(LIPO) -create $(PREFIX)/ppc/lib/libcrypto.a \
	                 $(PREFIX)/x86/lib/libcrypto.a \
	                 $(PREFIX)/x64/lib/libcrypto.a \
	                 $(PREFIX)/arm64/lib/libcrypto.a \
	                 -output $(PREFIX)/lib/libcrypto.a
	cp -R $(PREFIX)/x64/include/openssl/* $(PREFIX)/include/openssl/
	touch $@

$(PREFIX)/lib/libcrypto.a: $(STAMP_DIR)/openssl-universal.done
	@test -f $@
	@touch $@

$(PREFIX)/lib/libssl.a: $(STAMP_DIR)/openssl-universal.done
	@test -f $@
	@touch $@

# --- CURL ---
$(STAMP_DIR)/curl-ppc.done: $(STAMP_DIR)/curl-ppc.extract | $(PREFIX)/lib/libz.a $(PREFIX)/lib/libcrypto.a $(PREFIX)/lib/libssl.a
	@echo "--- Building curl (ppc) ---"
	cd $(CURL_PPC_SRC) && \
	CC="$(COMPILER_PPC) $(PPC_FLAGS)" AR="$(AR_LEGACY)" RANLIB="$(RANLIB_LEGACY)" \
	CFLAGS="$(OPT_FLAGS) $(COMMON_WARN_FLAGS)" \
	CPPFLAGS="-I$(PREFIX)/ppc/include -DHAVE_ATOMIC=0" \
	LDFLAGS="-L$(PREFIX)/ppc/lib" \
	LIBS="-lssl -lcrypto -lz -lpthread -ldl" \
	curl_cv_getaddrinfo_threadsafe=yes \
	./configure --host=powerpc-apple-darwin --disable-shared --enable-static \
	--enable-threaded-resolver --disable-alt-svc --disable-hsts \
	--disable-ldap --disable-ldaps --disable-symbol-hiding \
	--with-openssl=$(PREFIX)/ppc --with-zlib=$(PREFIX)/ppc \
	--prefix=$(PREFIX)/ppc && \
	sed -i 's|#define HAVE_ATOMIC 1|/* #undef HAVE_ATOMIC */|g' lib/curl_config.h && \
	sed -i 's|#define HAVE_STDATOMIC_H 1|/* #undef HAVE_STDATOMIC_H */|g' lib/curl_config.h && \
	grep -q '^#define HAVE_GETADDRINFO_THREADSAFE 1' lib/curl_config.h \
	  || { echo " [!] ppc: HAVE_GETADDRINFO_THREADSAFE not set"; exit 1; } && \
	make clean && make -j$(JOBS) -C lib install && make -j$(JOBS) -C include install
	touch $@

