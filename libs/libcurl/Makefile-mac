$(PREFIX)/lib/libcurl.a: $(STAMP_DIR)/curl-universal.done
	@test -f $@
	@touch $@

# --- AICURLConnection ---
$(STAMP_DIR)/aicc-ppc.done: AICURLConnection.m AICURLConnection.h | $(PREFIX)/lib/libcurl.a
	@echo "--- Building AICURLConnection (ppc) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/ppc/lib
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_PPC) $(COMPILER_PPC) $(PPC_FLAGS) $(OPT_FLAGS) -I$(PREFIX)/ppc/include -c AICURLConnection.m -o $(INTERMEDIATE)/AICURLConnection-ppc.o
	$(AR_LEGACY) rc $(PREFIX)/ppc/lib/libAICURLConnection.a $(INTERMEDIATE)/AICURLConnection-ppc.o
	$(RANLIB_LEGACY) $(PREFIX)/ppc/lib/libAICURLConnection.a
	touch $@

$(STAMP_DIR)/aicc-x86.done: AICURLConnection.m AICURLConnection.h | $(PREFIX)/lib/libcurl.a
	@echo "--- Building AICURLConnection (x86) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/x86/lib
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_X86) $(COMPILER_X86) $(X86_FLAGS) $(OPT_FLAGS) -I$(PREFIX)/x86/include -c AICURLConnection.m -o $(INTERMEDIATE)/AICURLConnection-x86.o
	$(AR_LEGACY) rc $(PREFIX)/x86/lib/libAICURLConnection.a $(INTERMEDIATE)/AICURLConnection-x86.o
