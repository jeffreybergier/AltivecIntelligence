	$(COMPILER_X64) $(X64_COMPILE_FLAGS) $(OPT_FLAGS) -I$(PREFIX)/x64/include -c AICURLConnection.m -o $(INTERMEDIATE)/AICURLConnection-x64.o
	$(AR_MODERN) rc $(PREFIX)/x64/lib/libAICURLConnection.a $(INTERMEDIATE)/AICURLConnection-x64.o
	$(RANLIB_MODERN) $(PREFIX)/x64/lib/libAICURLConnection.a
	touch $@

$(STAMP_DIR)/aicc-arm64.done: AICURLConnection.m AICURLConnection.h | $(PREFIX)/lib/libcurl.a
	@echo "--- Building AICURLConnection (arm64) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/arm64/lib
	$(COMPILER_ARM64) $(ARM64_COMPILE_FLAGS) $(OPT_FLAGS) -I$(PREFIX)/arm64/include -c AICURLConnection.m -o $(INTERMEDIATE)/AICURLConnection-arm64.o
	$(AR_MODERN) rc $(PREFIX)/arm64/lib/libAICURLConnection.a $(INTERMEDIATE)/AICURLConnection-arm64.o
	$(RANLIB_MODERN) $(PREFIX)/arm64/lib/libAICURLConnection.a
	touch $@

$(STAMP_DIR)/aicc-universal.done: $(STAMP_DIR)/aicc-ppc.done \
                                  $(STAMP_DIR)/aicc-x86.done \
                                  $(STAMP_DIR)/aicc-x64.done \
                                  $(STAMP_DIR)/aicc-arm64.done
	mkdir -p $(PREFIX)/lib
	$(LIPO) -create $(PREFIX)/ppc/lib/libAICURLConnection.a \
	                 $(PREFIX)/x86/lib/libAICURLConnection.a \
	                 $(PREFIX)/x64/lib/libAICURLConnection.a \
	                 $(PREFIX)/arm64/lib/libAICURLConnection.a \
	                 -output $(PREFIX)/lib/libAICURLConnection.a
