$(STAMP_DIR)/curl-arm64.done: $(STAMP_DIR)/curl-arm64.extract | $(PREFIX)/lib/libz.a $(PREFIX)/lib/libcrypto.a $(PREFIX)/lib/libssl.a
	@echo "--- Building curl (arm64) ---"
	cd $(CURL_ARM64_SRC) && \
	CC="$(COMPILER_ARM64) $(ARM64_FLAGS)" AR="$(AR_MODERN)" RANLIB="$(RANLIB_MODERN)" \
