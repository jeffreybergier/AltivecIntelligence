include libcurl_common.mk

# Versions
ZLIB_VER=1.2.13
OPENSSL_VER=1.1.1w
CURL_VER=7.88.1

# Directories
CWD=$(shell pwd)
BUILD_ROOT=$(CWD)/build-mac
INTERMEDIATE=$(BUILD_ROOT)/intermediate
PREFIX=$(BUILD_ROOT)/prefix
STAMP_DIR=$(BUILD_ROOT)/stamps
PUBLIC_LIB_DIR=$(BUILD_ROOT)/lib
PUBLIC_INCLUDE_DIR=$(BUILD_ROOT)/include
TARBALL_DIR=tarballs

# Source URLs
ZLIB_URL=https://zlib.net/fossils/zlib-$(ZLIB_VER).tar.gz
OPENSSL_URL=https://www.openssl.org/source/openssl-$(OPENSSL_VER).tar.gz
CURL_URL=https://curl.se/download/curl-$(CURL_VER).tar.gz

# Architecture Specific Flags
PPC_FLAGS=-arch ppc -mmacosx-version-min=$(MAC_MIN_PPC) -isysroot $(SDK_PPC_PATH) $(LEGACY_GCC_FLAGS)
X86_FLAGS=-arch i386 -mmacosx-version-min=$(MAC_MIN_X86) -isysroot $(SDK_X86_PATH) $(LEGACY_GCC_FLAGS)
X64_FLAGS=-target x86_64-apple-macos$(MAC_MIN_X64) -isysroot $(SDK_X64_PATH) -Wl,-platform_version,macos,$(MAC_MIN_X64),11.3 -fuse-ld=$(LD64_LLD) -B$(BIN_DIR)
ARM64_FLAGS=-target arm64-apple-macos$(MAC_MIN_ARM64) -isysroot $(SDK_ARM64_PATH) -Wl,-platform_version,macos,$(MAC_MIN_ARM64),11.3 -fuse-ld=$(LD64_LLD) -B$(BIN_DIR)
X64_COMPILE_FLAGS=-target x86_64-apple-macos$(MAC_MIN_X64) -isysroot $(SDK_X64_PATH) -B$(BIN_DIR)
ARM64_COMPILE_FLAGS=-target arm64-apple-macos$(MAC_MIN_ARM64) -isysroot $(SDK_ARM64_PATH) -B$(BIN_DIR)

ZLIB_TARBALL=$(TARBALL_DIR)/zlib-$(ZLIB_VER).tar.gz
OPENSSL_TARBALL=$(TARBALL_DIR)/openssl-$(OPENSSL_VER).tar.gz
CURL_TARBALL=$(TARBALL_DIR)/curl-$(CURL_VER).tar.gz

ZLIB_PPC_SRC=$(INTERMEDIATE)/zlib-$(ZLIB_VER)-ppc
ZLIB_X86_SRC=$(INTERMEDIATE)/zlib-$(ZLIB_VER)-x86
ZLIB_X64_SRC=$(INTERMEDIATE)/zlib-$(ZLIB_VER)-x64
ZLIB_ARM64_SRC=$(INTERMEDIATE)/zlib-$(ZLIB_VER)-arm64

OPENSSL_PPC_SRC=$(INTERMEDIATE)/openssl-$(OPENSSL_VER)-ppc
OPENSSL_X86_SRC=$(INTERMEDIATE)/openssl-$(OPENSSL_VER)-x86
OPENSSL_X64_SRC=$(INTERMEDIATE)/openssl-$(OPENSSL_VER)-x64
OPENSSL_ARM64_SRC=$(INTERMEDIATE)/openssl-$(OPENSSL_VER)-arm64

CURL_PPC_SRC=$(INTERMEDIATE)/curl-$(CURL_VER)-ppc
CURL_X86_SRC=$(INTERMEDIATE)/curl-$(CURL_VER)-x86
CURL_X64_SRC=$(INTERMEDIATE)/curl-$(CURL_VER)-x64
CURL_ARM64_SRC=$(INTERMEDIATE)/curl-$(CURL_VER)-arm64

PUBLIC_LIBS=$(PUBLIC_LIB_DIR)/libAICURLConnection.a \
            $(PUBLIC_LIB_DIR)/libcurl.a \
            $(PUBLIC_LIB_DIR)/libssl.a \
            $(PUBLIC_LIB_DIR)/libcrypto.a \
            $(PUBLIC_LIB_DIR)/libz.a

all: static

static: $(PUBLIC_LIBS) $(PUBLIC_LIB_DIR)/cacert.pem $(PUBLIC_INCLUDE_DIR)/.stamp verify-mac prune-build-files
	@echo "-----------------------------------------------------------"
	@echo "MAC QUAD-FAT (ppc, x86, x64, arm64) STATIC BUILD SUCCESSFUL"
	@echo "Libraries: $(PUBLIC_LIB_DIR)"
	@echo "Headers:   $(PUBLIC_INCLUDE_DIR)"
	@echo "-----------------------------------------------------------"

aicc: static
	@echo "AICURLConnection build successful."

aicc-analyze:
	@echo "--- Analyzing AICURLConnection (x64) ---"
	@$(COMPILER_X64) --analyze -Xanalyzer -analyzer-output=text \
		$(X64_COMPILE_FLAGS) $(OPT_FLAGS) -I$(PUBLIC_INCLUDE_DIR) AICURLConnection.m

verify-mac: $(PUBLIC_LIBS)
	@echo "--- Verifying Mac universal libraries ---"
	@missing=0; \
	for lib in $(PUBLIC_LIBS); do \
		info="`$(LIPO) -info $$lib 2>/dev/null`"; \
		echo "  > $$info"; \
		for arch in ppc i386 x86_64 arm64; do \
			echo "$$info" | grep -qw "$$arch" || { \
				echo " [!] ERROR: $$lib missing $$arch"; \
				missing=1; \
			}; \
		done; \
	done; \
	exit $$missing

prune-build-files:
	@echo "--- Removing Mac libcurl build-only files ---"
	rm -rf $(INTERMEDIATE) $(PREFIX) $(STAMP_DIR)

$(TARBALL_DIR):
	mkdir -p $@

$(ZLIB_TARBALL): | $(TARBALL_DIR)
	curl -fL $(ZLIB_URL) -o $@

$(OPENSSL_TARBALL): | $(TARBALL_DIR)
	curl -fL $(OPENSSL_URL) -o $@

$(CURL_TARBALL): | $(TARBALL_DIR)
	curl -fL $(CURL_URL) -o $@

$(PUBLIC_LIB_DIR)/cacert.pem: $(TARBALL_DIR)/cacert.pem
	mkdir -p $(PUBLIC_LIB_DIR)
	cp $< $@

$(TARBALL_DIR)/cacert.pem: | $(TARBALL_DIR)
	curl -fL https://curl.se/ca/cacert.pem -o $@

define extract_source
$1: $2
	mkdir -p $(INTERMEDIATE) $(STAMP_DIR)
	rm -rf $3
	mkdir -p $3
	tar -xf $2 -C $3 --strip-components=1
	touch $$@
endef

$(eval $(call extract_source,$(STAMP_DIR)/zlib-ppc.extract,$(ZLIB_TARBALL),$(ZLIB_PPC_SRC),zlib-$(ZLIB_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/zlib-x86.extract,$(ZLIB_TARBALL),$(ZLIB_X86_SRC),zlib-$(ZLIB_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/zlib-x64.extract,$(ZLIB_TARBALL),$(ZLIB_X64_SRC),zlib-$(ZLIB_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/zlib-arm64.extract,$(ZLIB_TARBALL),$(ZLIB_ARM64_SRC),zlib-$(ZLIB_VER)))

$(eval $(call extract_source,$(STAMP_DIR)/openssl-ppc.extract,$(OPENSSL_TARBALL),$(OPENSSL_PPC_SRC),openssl-$(OPENSSL_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/openssl-x86.extract,$(OPENSSL_TARBALL),$(OPENSSL_X86_SRC),openssl-$(OPENSSL_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/openssl-x64.extract,$(OPENSSL_TARBALL),$(OPENSSL_X64_SRC),openssl-$(OPENSSL_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/openssl-arm64.extract,$(OPENSSL_TARBALL),$(OPENSSL_ARM64_SRC),openssl-$(OPENSSL_VER)))

$(eval $(call extract_source,$(STAMP_DIR)/curl-ppc.extract,$(CURL_TARBALL),$(CURL_PPC_SRC),curl-$(CURL_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/curl-x86.extract,$(CURL_TARBALL),$(CURL_X86_SRC),curl-$(CURL_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/curl-x64.extract,$(CURL_TARBALL),$(CURL_X64_SRC),curl-$(CURL_VER)))
$(eval $(call extract_source,$(STAMP_DIR)/curl-arm64.extract,$(CURL_TARBALL),$(CURL_ARM64_SRC),curl-$(CURL_VER)))

# --- ZLIB ---
$(STAMP_DIR)/zlib-ppc.done: $(STAMP_DIR)/zlib-ppc.extract
	@echo "--- Building zlib (ppc) ---"
	cd $(ZLIB_PPC_SRC) && \
	./configure --static --prefix=$(PREFIX)/ppc && \
	sed -i 's|^CC=.*|CC=$(COMPILER_PPC) $(PPC_FLAGS)|g' Makefile && \
	sed -i 's|^AR=.*|AR=$(AR_LEGACY)|g' Makefile && \
	sed -i 's|^RANLIB=.*|RANLIB=$(RANLIB_LEGACY)|g' Makefile && \
	make clean && make -j$(JOBS) ARFLAGS="rc" install
	touch $@

$(STAMP_DIR)/zlib-x86.done: $(STAMP_DIR)/zlib-x86.extract
	@echo "--- Building zlib (x86) ---"
	cd $(ZLIB_X86_SRC) && \
	./configure --static --prefix=$(PREFIX)/x86 && \
	sed -i 's|^CC=.*|CC=$(COMPILER_X86) $(X86_FLAGS)|g' Makefile && \
	sed -i 's|^AR=.*|AR=$(AR_LEGACY)|g' Makefile && \
	sed -i 's|^RANLIB=.*|RANLIB=$(RANLIB_LEGACY)|g' Makefile && \
	make clean && make -j$(JOBS) ARFLAGS="rc" install
	touch $@

$(STAMP_DIR)/zlib-x64.done: $(STAMP_DIR)/zlib-x64.extract
	@echo "--- Building zlib (x64) ---"
	cd $(ZLIB_X64_SRC) && \
	./configure --static --prefix=$(PREFIX)/x64 && \
	sed -i 's|^CC=.*|CC=$(COMPILER_X64) $(X64_FLAGS)|g' Makefile && \
	sed -i 's|^AR=.*|AR=$(AR_MODERN)|g' Makefile && \
	sed -i 's|^RANLIB=.*|RANLIB=$(RANLIB_MODERN)|g' Makefile && \
	make clean && make -j$(JOBS) ARFLAGS="rc" install
	touch $@

$(STAMP_DIR)/zlib-arm64.done: $(STAMP_DIR)/zlib-arm64.extract
	@echo "--- Building zlib (arm64) ---"
	cd $(ZLIB_ARM64_SRC) && \
	./configure --static --prefix=$(PREFIX)/arm64 && \
	sed -i 's|^CC=.*|CC=$(COMPILER_ARM64) $(ARM64_FLAGS)|g' Makefile && \
	sed -i 's|^AR=.*|AR=$(AR_MODERN)|g' Makefile && \
	sed -i 's|^RANLIB=.*|RANLIB=$(RANLIB_MODERN)|g' Makefile && \
	make clean && make -j$(JOBS) ARFLAGS="rc" install
	touch $@

$(STAMP_DIR)/zlib-universal.done: $(STAMP_DIR)/zlib-ppc.done \
                                    $(STAMP_DIR)/zlib-x86.done \
                                    $(STAMP_DIR)/zlib-x64.done \
                                    $(STAMP_DIR)/zlib-arm64.done
	mkdir -p $(PREFIX)/lib $(PREFIX)/include
	$(LIPO) -create $(PREFIX)/ppc/lib/libz.a \
	                 $(PREFIX)/x86/lib/libz.a \
	                 $(PREFIX)/x64/lib/libz.a \
	                 $(PREFIX)/arm64/lib/libz.a \
	                 -output $(PREFIX)/lib/libz.a
	cp $(PREFIX)/x64/include/*.h $(PREFIX)/include/
	touch $@

$(PREFIX)/lib/libz.a: $(STAMP_DIR)/zlib-universal.done
	@test -f $@
	@touch $@

# --- OPENSSL ---
$(STAMP_DIR)/openssl-ppc.done: $(STAMP_DIR)/openssl-ppc.extract | $(PREFIX)/lib/libz.a
	@echo "--- Building OpenSSL (ppc) ---"
	cd $(OPENSSL_PPC_SRC) && \
	./Configure darwin-ppc-cc no-shared no-tests no-zlib --prefix=$(PREFIX)/ppc \
	CC="$(COMPILER_PPC)" AR="$(AR_LEGACY)" RANLIB="$(RANLIB_LEGACY)" \
	CFLAGS="$(PPC_FLAGS) $(OPT_FLAGS)" && \
	make clean && make -j$(JOBS) build_libs && make install_dev
	touch $@

$(STAMP_DIR)/openssl-x86.done: $(STAMP_DIR)/openssl-x86.extract | $(PREFIX)/lib/libz.a
	@echo "--- Building OpenSSL (x86) ---"
	cd $(OPENSSL_X86_SRC) && \
