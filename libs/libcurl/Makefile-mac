$(STAMP_DIR)/zlib-universal.done: $(STAMP_DIR)/zlib-ppc.done \
                                    $(STAMP_DIR)/zlib-x86.done \
                                    $(STAMP_DIR)/zlib-x64.done \
                                    $(STAMP_DIR)/zlib-arm64.done
	mkdir -p $(PREFIX)/lib $(PREFIX)/include
	$(LIPO) -create $(PREFIX)/ppc/lib/libz.a \
	                 $(PREFIX)/x86/lib/libz.a \
	                 $(PREFIX)/x64/lib/libz.a \
	                 $(PREFIX)/arm64/lib/libz.a \
	                 -output $(PREFIX)/lib/libz.a
	cp $(PREFIX)/x64/include/*.h $(PREFIX)/include/
	touch $@

$(PREFIX)/lib/libz.a: $(STAMP_DIR)/zlib-universal.done
	@test -f $@
	@touch $@

# --- OPENSSL ---
$(STAMP_DIR)/openssl-ppc.done: $(STAMP_DIR)/openssl-ppc.extract | $(PREFIX)/lib/libz.a
	@echo "--- Building OpenSSL (ppc) ---"
	cd $(OPENSSL_PPC_SRC) && \
	./Configure darwin-ppc-cc no-shared no-tests no-zlib --prefix=$(PREFIX)/ppc \
	CC="$(COMPILER_PPC)" AR="$(AR_LEGACY)" RANLIB="$(RANLIB_LEGACY)" \
	CFLAGS="$(PPC_FLAGS) $(OPT_FLAGS)" && \
	make clean && make -j$(JOBS) build_libs && make install_dev
	touch $@

