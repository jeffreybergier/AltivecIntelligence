# --- AICURLConnection ---
$(STAMP_DIR)/aicc-ppc.done: AICURLConnection.m AICURLConnection.h | $(PREFIX)/lib/libcurl.a
	@echo "--- Building AICURLConnection (ppc) ---"
	mkdir -p $(INTERMEDIATE) $(PREFIX)/ppc/lib
	MACOSX_DEPLOYMENT_TARGET=$(MAC_MIN_PPC) $(COMPILER_PPC) $(PPC_FLAGS) $(OPT_FLAGS) -I$(PREFIX)/ppc/include -c AICURLConnection.m -o $(INTERMEDIATE)/AICURLConnection-ppc.o
	$(AR_LEGACY) rc $(PREFIX)/ppc/lib/libAICURLConnection.a $(INTERMEDIATE)/AICURLConnection-ppc.o
	$(RANLIB_LEGACY) $(PREFIX)/ppc/lib/libAICURLConnection.a
