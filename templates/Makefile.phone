# Thin template for app repos that use the Altivec GHCR image
# (no submodule needed — /altivec/ is provided by the image).

APP_NAME = MyPhoneApp
SOURCES = main.m AppDelegate.m
RES_DIR = Resources

# Optional override if libcurl is required for this app:
# LIBCURL_REQUIRED = 1
# LIBCURL_DIR = /altivec/libs/libcurl/build-phone

include /altivec/altivec_common_phone.mk
